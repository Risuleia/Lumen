import { IslandData, Config } from "../global.slint";
import { Metrics } from "../theme/Metrics.slint";
import { Colors } from "../theme/Colors.slint";
import { ElidedText } from "../components/ElidedText.slint";

component CollapsedNotification inherits HorizontalLayout {
    alignment: start;
    spacing: 1rem;

    Rectangle {
        private property <length> size: 32px * Config.scale;

        horizontal-stretch: 0;
        height: size;
        width: size;
        border-radius: Metrics.radius-sm;
        clip: true;
        y: (parent.height - self.height) / 2;

        Image {
            width: parent.width;
            height: parent.height;
            source: IslandData.notification.app-icon;
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 4px;
        y: (parent.height - self.height) / 2;

        ElidedText {
            text: IslandData.notification.title;
            font-size: Metrics.fs-125;
            txt-color: Colors.text-primary;
        }

        ElidedText {
            text: IslandData.notification.body;
            txt-color: Colors.text-secondary;
            font-size: Metrics.fs-120;
            vertical-stretch: 0;
        }
    }
}

component ExpandedNotification inherits VerticalLayout {
    alignment: start;
    spacing: 1rem;

    HorizontalLayout {
        width: parent.width;
        alignment: start;
        spacing: 8px;
        vertical-stretch: 0;

        Rectangle {
            private property <length> size: 18px * Config.scale;

            y: (parent.height - self.height) / 2;

            height: size;
            width: size;
            border-radius: Metrics.radius-sm;
            clip: true;

            Image {
                width: parent.width;
                height: parent.height;
                source: IslandData.notification.app-icon;
            }
        }

        Text {
            text: IslandData.notification.app-name;
            horizontal-alignment: left;
            vertical-alignment: center;
            color: Colors.text-primary;
            font-size: Metrics.fs-100;
            font-weight: 500;
            overflow: elide;
            letter-spacing: -0.2px;
        }
    }

    VerticalLayout {
        alignment: start;
        spacing: 4px;

        Text {
            vertical-stretch: 0;
            text: IslandData.notification.title;
            overflow: clip;
            font-size: Metrics.fs-150;
            font-weight: 600;
            color: Colors.text-primary;
            horizontal-alignment: left;
            letter-spacing: -0.2px;
        }

        Text {
            text: IslandData.notification.body;
            overflow: elide;
            font-size: Metrics.fs-125;
            color: Colors.text-secondary;
            horizontal-alignment: left;
            letter-spacing: -0.2px;
            wrap: word-wrap;
        }
    }
}

export component Notification inherits Rectangle {
    clip: true;

    if IslandData.expanded: ExpandedNotification {
        width: root.width;
        height: root.height;
    }
    if !IslandData.expanded: CollapsedNotification {
        width: root.width;
        height: root.height;
    }
}
